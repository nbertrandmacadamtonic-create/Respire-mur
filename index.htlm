<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>Respire MUR</title>

<style>
:root{
  --bg:#0b1220;
  --card:rgba(255,255,255,.12);
  --line:rgba(255,255,255,.20);
  --text:#f8fafc;
  --muted:rgba(248,250,252,.70);
  --accent:#22c55e;
  --blue:#3b82f6;
  --green:#22c55e;
  --orange:#f59e0b;
  --red:#ef4444;
}

*{box-sizing:border-box}

html,body{
  width:100%;
  max-width:100%;
  overflow-x:hidden;
}

body{
  margin:0;
  min-height:100vh;
  font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","Segoe UI",Arial,sans-serif;
  color:var(--text);
  background:
    radial-gradient(circle at top left,rgba(59,130,246,.40),transparent 34%),
    radial-gradient(circle at top right,rgba(239,68,68,.28),transparent 34%),
    radial-gradient(circle at bottom,rgba(34,197,94,.22),transparent 40%),
    var(--bg);
}

button,input,select{
  font:inherit;
  max-width:100%;
}

.app{
  width:100%;
  max-width:560px;
  margin:auto;
  min-height:100vh;
  padding:calc(14px + env(safe-area-inset-top)) 12px calc(92px + env(safe-area-inset-bottom));
}

.top{
  display:flex;
  align-items:center;
  gap:12px;
  margin-bottom:12px;
}

.logo{
  width:50px;
  height:50px;
  border-radius:18px;
  background:
    linear-gradient(135deg,transparent 0 35%,rgba(255,255,255,.9) 36% 40%,transparent 41%),
    conic-gradient(from 220deg,var(--blue),var(--green),var(--orange),var(--red),var(--blue));
  box-shadow:0 18px 50px rgba(0,0,0,.36);
}

.kicker{
  margin:0;
  color:var(--muted);
  font-size:10px;
  letter-spacing:.15em;
  text-transform:uppercase;
}

h1{
  margin:0;
  font-size:30px;
  letter-spacing:-.04em;
}

h2{
  margin:0;
  font-size:19px;
  line-height:1.15;
}

.card{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:24px;
  padding:15px;
  margin-bottom:11px;
  box-shadow:0 20px 60px rgba(0,0,0,.30);
  backdrop-filter:blur(22px);
}

.tab-panel{
  display:none;
}

.tab-panel.active{
  display:block;
}

.status{
  display:grid;
  grid-template-columns:1fr auto;
  gap:10px;
  align-items:start;
}

.help{
  margin:8px 0 0;
  color:var(--muted);
  line-height:1.35;
  font-size:14px;
}

.zone{
  display:inline-flex;
  align-items:center;
  gap:7px;
  padding:7px 10px;
  border-radius:999px;
  background:rgba(255,255,255,.14);
  border:1px solid var(--accent);
  font-weight:900;
  white-space:nowrap;
  font-size:13px;
  color:white;
  cursor:pointer;
}

.zone:active{
  transform:scale(.96);
}

.dot{
  width:11px;
  height:11px;
  border-radius:50%;
  background:var(--accent);
}

.protocol-box{
  margin-top:12px;
}

.protocol-label{
  display:block;
  color:var(--muted);
  font-size:12px;
  margin-bottom:6px;
}

select{
  width:100%;
  border:1px solid var(--line);
  background:rgba(0,0,0,.22);
  color:white;
  border-radius:16px;
  padding:12px;
  outline:none;
  font-size:14px;
}

.scale{
  margin-top:13px;
}

.scale-labels{
  display:flex;
  justify-content:space-between;
  color:var(--muted);
  font-size:12px;
  margin-bottom:8px;
}

.scale-labels span:nth-child(2){text-align:center}
.scale-labels span:nth-child(3){text-align:right}

input[type=range]{
  appearance:none;
  -webkit-appearance:none;
  width:100%;
  height:20px;
  border-radius:999px;
  background:linear-gradient(90deg,var(--blue),var(--green),var(--red));
  outline:none;
}

input[type=range]::-webkit-slider-thumb{
  appearance:none;
  -webkit-appearance:none;
  width:38px;
  height:38px;
  border-radius:50%;
  background:white;
  border:5px solid var(--accent);
  box-shadow:0 8px 24px rgba(0,0,0,.36);
}

.compact-rhythm{
  margin-top:12px;
  display:grid;
  grid-template-columns:1fr auto 1fr;
  gap:10px;
  align-items:center;
  padding:12px;
  border-radius:20px;
  background:rgba(0,0,0,.18);
  border:1px solid var(--line);
  text-align:center;
}

.rhythm-number span{
  display:block;
  font-size:46px;
  line-height:.9;
  font-weight:950;
  letter-spacing:-.06em;
}

.rhythm-number small{
  display:block;
  margin-top:5px;
  color:var(--muted);
  text-transform:uppercase;
  letter-spacing:.12em;
  font-size:11px;
}

.slash{
  font-size:34px;
  font-weight:950;
  color:var(--muted);
}

.message{
  margin:10px 0 0;
  font-size:14px;
  line-height:1.35;
  color:var(--muted);
}

.quick{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:8px;
  margin-top:10px;
}

.quick button{
  border:1px solid var(--line);
  background:rgba(255,255,255,.12);
  color:white;
  border-radius:16px;
  padding:10px 6px;
  font-size:13px;
  font-weight:900;
}

.quick button.active{
  background:white;
  color:#07111f;
}

.breath-card{
  text-align:center;
  padding-top:12px;
}

.mini-info{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:8px;
}

.info-box{
  border-radius:16px;
  padding:10px;
  background:rgba(255,255,255,.10);
  border:1px solid var(--line);
}

.info-box small{
  color:var(--muted);
  font-size:12px;
}

.info-box strong{
  display:block;
  margin-top:2px;
  font-size:19px;
}

.stage{
  height:250px;
  display:grid;
  place-items:center;
  position:relative;
}

.progress-ring{
  position:absolute;
  width:208px;
  height:208px;
  transform:rotate(-90deg);
}

.progress-bg,
.progress-line{
  fill:none;
  stroke-width:8;
}

.progress-bg{
  stroke:rgba(255,255,255,.12);
}

.progress-line{
  stroke:var(--accent);
  stroke-linecap:round;
  stroke-dasharray:616;
  stroke-dashoffset:616;
  transition:stroke-dashoffset .15s linear;
}

.orb{
  width:148px;
  height:148px;
  border-radius:50%;
  display:grid;
  place-items:center;
  transform:scale(.80);
  transition:transform linear, background .25s, box-shadow .25s;
  background:
    radial-gradient(circle at 36% 27%,rgba(255,255,255,.95),rgba(255,255,255,.20) 28%,transparent 48%),
    radial-gradient(circle,var(--accent),rgba(255,255,255,.12));
  box-shadow:
    0 0 46px var(--accent),
    inset 0 0 22px rgba(255,255,255,.32);
  z-index:1;
  cursor:pointer;
  border:0;
  color:white;
}

.orb span{
  font-size:20px;
  font-weight:950;
  line-height:1.08;
  padding:0 16px;
}

.phase-hint{
  position:absolute;
  bottom:4px;
  color:var(--muted);
  font-size:13px;
  padding:0 16px;
}

.secondary{
  width:100%;
  margin-top:9px;
  border:1px solid var(--line);
  border-radius:18px;
  padding:13px;
  background:rgba(255,255,255,.15);
  color:white;
  font-size:15px;
  font-weight:900;
}

.danger{
  border-color:rgba(239,68,68,.6);
}

.manual-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
}

.manual-grid label{
  font-size:13px;
  color:var(--muted);
}

.manual-grid input{
  margin-top:6px;
  width:100%;
  border:1px solid var(--line);
  border-radius:14px;
  padding:10px;
  background:rgba(255,255,255,.12);
  color:white;
  font-size:16px;
}

.duration-row{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:8px;
}

.round{
  width:44px;
  height:44px;
  border:0;
  border-radius:50%;
  background:rgba(255,255,255,.16);
  color:white;
  font-size:24px;
  font-weight:900;
}

.duration{
  flex:1;
  border-radius:18px;
  padding:10px;
  background:rgba(255,255,255,.10);
  border:1px solid var(--line);
}

.duration small{
  color:var(--muted);
  font-size:12px;
}

.duration strong{
  display:block;
  margin-top:2px;
  font-size:19px;
}

.history-tabs{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:8px;
  margin-top:12px;
}

.history-tabs button{
  border:1px solid var(--line);
  border-radius:15px;
  padding:10px 6px;
  background:rgba(255,255,255,.12);
  color:white;
  font-weight:900;
  font-size:13px;
}

.history-tabs button.active{
  background:white;
  color:#07111f;
}

.history-summary{
  margin-top:12px;
  padding:12px;
  border-radius:16px;
  background:rgba(0,0,0,.18);
  border:1px solid var(--line);
  color:var(--muted);
  line-height:1.4;
  font-size:14px;
}

.chart{
  margin-top:12px;
  padding:12px 8px 8px;
  border-radius:18px;
  background:rgba(0,0,0,.18);
  border:1px solid var(--line);
  overflow:hidden;
}

.chart-bars{
  height:110px;
  display:flex;
  align-items:flex-end;
  justify-content:space-around;
  gap:6px;
  min-width:0;
}

.chart-col{
  flex:1;
  min-width:0;
  text-align:center;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:flex-end;
  height:100%;
}

.chart-bar{
  width:100%;
  max-width:28px;
  min-height:5px;
  border-radius:10px 10px 4px 4px;
  background:var(--accent);
}

.chart-value{
  font-size:10px;
  color:var(--muted);
  margin-bottom:5px;
}

.chart-label{
  margin-top:7px;
  font-size:10px;
  color:var(--muted);
  white-space:nowrap;
  max-width:52px;
  overflow:hidden;
  text-overflow:ellipsis;
}

.chart-empty{
  color:var(--muted);
  padding:18px;
  text-align:center;
  font-size:14px;
}

.history-list{
  margin-top:10px;
  display:grid;
  gap:8px;
  max-height:260px;
  overflow:auto;
  padding-right:2px;
}

.history-item{
  display:grid;
  grid-template-columns:auto 1fr auto;
  gap:9px;
  align-items:center;
  padding:10px;
  border-radius:16px;
  background:rgba(255,255,255,.10);
  border:1px solid var(--line);
  overflow:hidden;
}

.history-item div{
  min-width:0;
}

.history-item strong{
  font-size:14px;
}

.history-item small{
  color:var(--muted);
  font-size:12px;
  word-break:break-word;
}

.history-dot{
  width:11px;
  height:11px;
  border-radius:50%;
  background:var(--accent);
}

.history-actions{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:8px;
  margin-top:10px;
}

.import-label{
  display:block;
  text-align:center;
  cursor:pointer;
}

.notice{
  padding:0 6px;
  color:var(--muted);
  line-height:1.45;
  font-size:13px;
}

.tabbar{
  position:fixed;
  left:50%;
  bottom:calc(10px + env(safe-area-inset-bottom));
  transform:translateX(-50%);
  width:min(536px,calc(100% - 20px));
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:8px;
  padding:8px;
  border-radius:24px;
  background:rgba(11,18,32,.82);
  border:1px solid var(--line);
  backdrop-filter:blur(22px);
  box-shadow:0 20px 60px rgba(0,0,0,.42);
  z-index:50;
}

.tabbar button{
  border:0;
  border-radius:18px;
  padding:11px 6px;
  background:rgba(255,255,255,.10);
  color:white;
  font-size:13px;
  font-weight:950;
}

.tabbar button.active{
  background:white;
  color:#07111f;
}

.flash{
  animation:flash .28s ease-out;
}

@keyframes flash{
  0%{transform:scale(1.02); background:rgba(255,255,255,.22)}
  100%{transform:scale(1); background:rgba(0,0,0,.18)}
}

@media(max-width:390px){
  .app{
    padding-left:10px;
    padding-right:10px;
  }

  h1{font-size:28px}
  h2{font-size:18px}

  .card{
    border-radius:22px;
    padding:13px;
  }

  .rhythm-number span{font-size:40px}
  .slash{font-size:30px}

  .stage{height:230px}

  .orb{
    width:138px;
    height:138px;
  }

  .progress-ring{
    width:194px;
    height:194px;
  }

  .history-item{
    grid-template-columns:auto 1fr;
  }

  .history-item > small:last-child{
    grid-column:2;
    justify-self:start;
  }

  .history-actions{
    grid-template-columns:1fr;
  }
}
</style>
</head>

<body>
<main class="app">

<header class="top">
  <div class="logo"></div>
  <div>
    <p class="kicker">Méthode MUR</p>
    <h1>Respire MUR</h1>
  </div>
</header>

<section id="tabBreath" class="tab-panel active">

  <section class="card">
    <div class="status">
      <div>
        <h2>Comment est votre neuroFlex aujourd’hui&nbsp;?</h2>
        <p class="help">
          Plus d’élan, plus d’équilibre ou plus de calme.
        </p>
      </div>

      <button id="zoneButton" class="zone" type="button">
        <span class="dot"></span>
        <span id="zoneName">Vert</span>
      </button>
    </div>

    <div class="protocol-box">
      <label class="protocol-label" for="protocolSelect">Choisir une respiration</label>
      <select id="protocolSelect">
        <option value="365">Respiration 365 — équilibre — 5 min</option>
        <option value="coherence">Cohérence 5/5 — stabilité — 5 min</option>
        <option value="carree">Respiration carrée 4/4/4/4 — recentrage — 3 min</option>
        <option value="46">Respiration 4/6 — apaisement — 3 min</option>
        <option value="frein">Respiration frein 3/8 — redescente — 2 min</option>
        <option value="boost">Respiration boost 5/2 — dynamisation — 1 min</option>
        <option value="478">Respiration 4/7/8 — retour au calme — 2 min</option>
      </select>
    </div>

    <div class="scale">
      <div class="scale-labels">
        <span>Bleu<br><small>dynamiser</small></span>
        <span>Vert<br><small>équilibrer</small></span>
        <span>Rouge<br><small>freiner</small></span>
      </div>
      <input id="slider" type="range" min="-3" max="3" step="1" value="0">
    </div>

    <div id="livePanel" class="compact-rhythm">
      <div class="rhythm-number">
        <span id="inspire">5</span>
        <small>inspire</small>
      </div>
      <div class="slash">/</div>
      <div class="rhythm-number">
        <span id="expire">5</span>
        <small>expire</small>
      </div>
    </div>

    <p id="message" class="message">Équilibre : respiration 365, régulière et stable.</p>

    <div class="quick">
      <button id="btnBleu" type="button">Bleu<br><small>Boost</small></button>
      <button id="btnVert" type="button" class="active">Vert<br><small>365</small></button>
      <button id="btnRouge" type="button">Rouge<br><small>Frein</small></button>
    </div>
  </section>

  <section class="card breath-card">
    <div class="mini-info">
      <div class="info-box">
        <small>Temps restant</small>
        <strong id="temps">05:00</strong>
      </div>
      <div class="info-box">
        <small>Cycle</small>
        <strong id="cycle">5 / 5</strong>
      </div>
    </div>

    <div class="stage">
      <svg class="progress-ring" viewBox="0 0 220 220">
        <circle class="progress-bg" cx="110" cy="110" r="98"></circle>
        <circle id="progressCircle" class="progress-line" cx="110" cy="110" r="98"></circle>
      </svg>

      <button id="orb" class="orb" type="button">
        <span id="phase">Êtes-vous prêt ?</span>
      </button>

      <div id="phaseHint" class="phase-hint">
        Touchez le cercle pour commencer.
      </div>
    </div>

    <button id="stop" class="secondary danger" type="button" hidden>Arrêter</button>
    <button id="soundToggle" class="secondary" type="button">Activer le son</button>
  </section>

</section>

<section id="tabHistory" class="tab-panel">
  <section class="card">
    <h2>Historique neuroFlex</h2>

    <div class="history-tabs">
      <button id="historyDay" class="active" type="button">Jour</button>
      <button id="historyWeek" type="button">Semaine</button>
      <button id="historyMonth" type="button">Mois</button>
    </div>

    <div id="historySummary" class="history-summary">
      Aucune séance enregistrée pour le moment.
    </div>

    <div id="historyChart" class="chart"></div>

    <div id="historyList" class="history-list"></div>
  </section>
</section>

<section id="tabSettings" class="tab-panel">

  <section class="card">
    <h2>Réglages</h2>

    <div class="duration-row" style="margin-top:12px;">
      <button id="moins" class="round" type="button">−</button>
      <div class="duration">
        <small>Durée de séance</small>
        <strong><span id="duree">5</span> min</strong>
      </div>
      <button id="plus" class="round" type="button">+</button>
    </div>

    <div class="manual-grid" style="margin-top:12px;">
      <label>Inspiration
        <input id="manualInspire" type="number" min="1" max="12" value="5">
      </label>
      <label>Pause haute
        <input id="manualPauseH" type="number" min="0" max="12" value="0">
      </label>
      <label>Expiration
        <input id="manualExpire" type="number" min="1" max="15" value="5">
      </label>
      <label>Pause basse
        <input id="manualPauseB" type="number" min="0" max="12" value="0">
      </label>
    </div>

    <button id="applyManual" class="secondary" type="button">Appliquer le réglage manuel</button>
  </section>

  <section class="card">
    <h2>Sauvegarde</h2>

    <p class="help">
      Exportez votre historique avant de changer de version ou de téléphone.
    </p>

    <div class="history-actions">
      <button id="exportHistory" class="secondary" type="button">
        Exporter
      </button>

      <label class="secondary import-label">
        Importer
        <input id="importHistory" type="file" accept=".json" style="display:none;">
      </label>
    </div>

    <button id="clearHistory" class="secondary" type="button">
      Effacer l’historique
    </button>
  </section>

  <p class="notice">
    Cette application est un outil de guidage respiratoire.
    En cas de malaise, de vertige ou de gêne respiratoire, arrêtez l’exercice.
  </p>

</section>

<nav class="tabbar">
  <button class="active" type="button" data-tab="tabBreath">Respirer</button>
  <button type="button" data-tab="tabHistory">Historique</button>
  <button type="button" data-tab="tabSettings">Réglages</button>
</nav>

</main>

<script>
const $ = id => document.getElementById(id);

let duree = 5;
let running = false;
let stopAsked = false;
let endTime = 0;
let timer = null;
let raf = null;
let sessionStart = 0;
let sessionTotal = 0;
let historyView = "day";

let soundEnabled = false;
let audioContext = null;
let masterGain = null;
let currentNoiseSource = null;

let breath = {
  i:5,
  ph:0,
  e:5,
  pb:0,
  zone:"Vert",
  name:"365",
  color:"#22c55e",
  text:"Équilibre : respiration 365, régulière et stable.",
  slider:0
};

const protocols = {
  "365":{i:5, ph:0, e:5, pb:0, duration:5, zone:"Vert", name:"365", color:"#22c55e", text:"Respiration 365 : 5 minutes pour installer un rythme stable.", slider:0},
  "coherence":{i:5, ph:0, e:5, pb:0, duration:5, zone:"Vert", name:"Cohérence", color:"#22c55e", text:"Cohérence 5/5 : inspiration et expiration s’équilibrent.", slider:0},
  "carree":{i:4, ph:4, e:4, pb:4, duration:3, zone:"Vert", name:"Carrée", color:"#22c55e", text:"Respiration carrée : un cadre simple pour se recentrer.", slider:0},
  "46":{i:4, ph:0, e:6, pb:0, duration:3, zone:"Orange / rouge", name:"4 / 6", color:"#f97316", text:"Respiration 4/6 : l’expiration prend le dessus pour réguler.", slider:2},
  "frein":{i:3, ph:0, e:8, pb:0, duration:2, zone:"Rouge", name:"Frein", color:"#ef4444", text:"Respiration frein : expiration longue pour redescendre.", slider:3},
  "boost":{i:5, ph:0, e:2, pb:0, duration:1, zone:"Bleu", name:"Boost", color:"#3b82f6", text:"Respiration boost : inspiration dominante pour relancer.", slider:-2},
  "478":{i:4, ph:7, e:8, pb:0, duration:2, zone:"Rouge", name:"4 / 7 / 8", color:"#ef4444", text:"Respiration 4/7/8 : ralentir, tenir, puis relâcher longtemps.", slider:3}
};

const sliderMap = {
  "-3": {i:6, ph:0, e:2, pb:0, duration:1, zone:"Bleu profond", name:"Boost +", color:"#2563eb", text:"Bleu profond : l’inspiration domine nettement pour dynamiser.", slider:-3},
  "-2": {i:5, ph:0, e:2, pb:0, duration:1, zone:"Bleu", name:"Boost", color:"#3b82f6", text:"Bleu : on donne plus de place à l’inspiration.", slider:-2},
  "-1": {i:4, ph:0, e:3, pb:0, duration:2, zone:"Bleu léger", name:"Relance", color:"#38bdf8", text:"Bleu léger : relance douce, proche de l’équilibre.", slider:-1},
  "0": {i:5, ph:0, e:5, pb:0, duration:5, zone:"Vert", name:"365", color:"#22c55e", text:"Équilibre : respiration 365, régulière et stable.", slider:0},
  "1": {i:4, ph:0, e:5, pb:0, duration:3, zone:"Orange léger", name:"Apaisement", color:"#f59e0b", text:"Orange léger : l’expiration prend un peu plus de place.", slider:1},
  "2": {i:4, ph:0, e:6, pb:0, duration:3, zone:"Orange / rouge", name:"Régulation", color:"#f97316", text:"Orange / rouge : expiration longue pour réguler.", slider:2},
  "3": {i:3, ph:0, e:8, pb:0, duration:2, zone:"Rouge", name:"Frein", color:"#ef4444", text:"Rouge : l’expiration domine franchement pour redescendre.", slider:3}
};

function initAudio(){
  if(!audioContext){
    audioContext = new (window.AudioContext || window.webkitAudioContext)();
    masterGain = audioContext.createGain();
    masterGain.gain.value = 0.55;
    masterGain.connect(audioContext.destination);
  }
  if(audioContext.state === "suspended") audioContext.resume();
}

function makeNoiseBuffer(){
  const bufferSize = audioContext.sampleRate * 2;
  const buffer = audioContext.createBuffer(1, bufferSize, audioContext.sampleRate);
  const data = buffer.getChannelData(0);
  for(let i=0; i<bufferSize; i++) data[i] = (Math.random() * 2 - 1) * 0.7;
  return buffer;
}

function playSoftClick(){
  if(!soundEnabled) return;
  initAudio();

  const osc = audioContext.createOscillator();
  const gain = audioContext.createGain();
  osc.connect(gain);
  gain.connect(masterGain);

  osc.type = "sine";
  osc.frequency.setValueAtTime(220, audioContext.currentTime);

  gain.gain.setValueAtTime(0.0001, audioContext.currentTime);
  gain.gain.linearRampToValueAtTime(0.11, audioContext.currentTime + 0.02);
  gain.gain.linearRampToValueAtTime(0.0001, audioContext.currentTime + 0.16);

  osc.start();
  osc.stop(audioContext.currentTime + 0.16);
}

function playBreathSound(type, duration){
  if(!soundEnabled) return;
  initAudio();

  if(currentNoiseSource){
    try{ currentNoiseSource.stop(); } catch(e){}
    currentNoiseSource = null;
  }

  const noise = audioContext.createBufferSource();
  noise.buffer = makeNoiseBuffer();
  noise.loop = true;

  const filter = audioContext.createBiquadFilter();
  filter.type = "bandpass";
  filter.Q.value = 0.8;

  const gain = audioContext.createGain();
  noise.connect(filter);
  filter.connect(gain);
  gain.connect(masterGain);

  const now = audioContext.currentTime;

  if(type === "inspire"){
    filter.frequency.setValueAtTime(520, now);
    filter.frequency.linearRampToValueAtTime(900, now + duration);
  }

  if(type === "expire"){
    filter.frequency.setValueAtTime(760, now);
    filter.frequency.linearRampToValueAtTime(360, now + duration);
  }

  gain.gain.setValueAtTime(0.0001, now);
  gain.gain.linearRampToValueAtTime(0.13, now + 0.35);
  gain.gain.linearRampToValueAtTime(0.0001, now + duration);

  noise.start(now);
  noise.stop(now + duration);
  currentNoiseSource = noise;
}

function unlockAudio(){
  initAudio();
  soundEnabled = true;
  $("soundToggle").textContent = "Son : activé";
  playSoftClick();
}

function setActiveTab(tabId){
  document.querySelectorAll(".tab-panel").forEach(panel => {
    panel.classList.remove("active");
  });

  document.querySelectorAll(".tabbar button").forEach(button => {
    button.classList.remove("active");
  });

  $(tabId).classList.add("active");
  document.querySelector(`.tabbar button[data-tab="${tabId}"]`).classList.add("active");

  if(tabId === "tabHistory"){
    renderHistory();
  }
}

function setProtocol(key){
  if(running) return;
  breath = {...protocols[key]};
  duree = breath.duration;
  $("protocolSelect").value = key;
  render(true);
}

function setBreathFromSlider(value){
  if(running) return;
  breath = {...sliderMap[String(value)]};
  duree = breath.duration;
  render(true);
}

function render(flash=false){
  document.documentElement.style.setProperty("--accent", breath.color);

  $("slider").value = breath.slider ?? 0;
  $("zoneName").textContent = breath.zone;
  $("inspire").textContent = breath.i;
  $("expire").textContent = breath.e;
  $("message").textContent = breath.text;
  $("cycle").textContent = breath.i + " / " + breath.e;
  $("duree").textContent = duree;
  $("temps").textContent = format(duree * 60);

  $("manualInspire").value = breath.i;
  $("manualPauseH").value = breath.ph;
  $("manualExpire").value = breath.e;
  $("manualPauseB").value = breath.pb;

  const sliderValue = Number($("slider").value);
  $("btnBleu").classList.toggle("active", sliderValue < 0);
  $("btnVert").classList.toggle("active", sliderValue === 0);
  $("btnRouge").classList.toggle("active", sliderValue > 0);

  setProgress(0);

  if(!running){
    $("phase").textContent = "Êtes-vous prêt ?";
    $("phaseHint").textContent = "Touchez le cercle pour commencer.";
  }

  if(flash){
    $("livePanel").classList.remove("flash");
    void $("livePanel").offsetWidth;
    $("livePanel").classList.add("flash");
  }
}

function setSlider(v){
  $("slider").value = v;
  setBreathFromSlider(v);
}

function changeZoneByButton(){
  if(running) return;

  const current = Number($("slider").value);
  let next;

  if(current === 0){
    next = -2;
  } else if(current < 0){
    next = 2;
  } else if(current === 2){
    next = 3;
  } else {
    next = 0;
  }

  playSoftClick();
  setSlider(next);
}

function num(id,min,max){
  const n = Math.round(Number($(id).value));
  if(Number.isNaN(n)) return min;
  return Math.max(min, Math.min(max,n));
}

function applyManual(){
  if(running) return;
  playSoftClick();

  const i = num("manualInspire",1,12);
  const ph = num("manualPauseH",0,12);
  const e = num("manualExpire",1,15);
  const pb = num("manualPauseB",0,12);

  let color = "#22c55e";
  let zone = "Vert personnalisé";
  let text = "Rythme personnalisé équilibrant.";
  let slider = 0;

  if(i > e){
    color = "#3b82f6";
    zone = "Bleu personnalisé";
    text = "Rythme personnalisé dynamisant : inspiration dominante.";
    slider = -1;
  }

  if(e > i){
    color = "#ef4444";
    zone = "Rouge personnalisé";
    text = "Rythme personnalisé apaisant : expiration dominante.";
    slider = 1;
  }

  breath = {i, ph, e, pb, zone, name:"Manuel", color, text, slider, duration:duree};
  render(true);
  setActiveTab("tabBreath");
}

function format(s){
  s = Math.max(0, Math.ceil(s));
  const m = Math.floor(s/60);
  const r = s%60;
  return String(m).padStart(2,"0") + ":" + String(r).padStart(2,"0");
}

function wait(ms){
  return new Promise(resolve => setTimeout(resolve, ms));
}

function setProgress(progress){
  const circumference = 2 * Math.PI * 98;
  const offset = circumference * (1 - Math.max(0, Math.min(1, progress)));
  $("progressCircle").style.strokeDasharray = String(circumference);
  $("progressCircle").style.strokeDashoffset = String(offset);
}

function animateProgress(){
  if(!running) return;
  const progress = (Date.now() - sessionStart) / sessionTotal;
  setProgress(progress);
  raf = requestAnimationFrame(animateProgress);
}

async function phase(label, seconds, scale){
  if(seconds <= 0 || stopAsked) return;

  $("phase").textContent = label;

  if(label === "Inspirez") playBreathSound("inspire", seconds);
  if(label === "Expirez") playBreathSound("expire", seconds);

  $("phaseHint").textContent =
    label === "Inspirez" ? "Le cercle s’ouvre : inspirez sans forcer." :
    label === "Expirez" ? "Le cercle se referme : laissez sortir l’air." :
    label === "Gardez" ? "Gardez l’air seulement si c’est confortable." :
    "Petite pause, sans blocage.";

  $("orb").style.transitionDuration = seconds + "s";
  $("orb").style.transform = "scale(" + scale + ")";
  await wait(seconds * 1000);
}

async function runSession(){
  if(running) return;

  setActiveTab("tabBreath");
  playSoftClick();

  running = true;
  stopAsked = false;

  $("stop").hidden = false;
  $("slider").disabled = true;
  $("protocolSelect").disabled = true;

  sessionTotal = duree * 60 * 1000;
  sessionStart = Date.now();
  endTime = sessionStart + sessionTotal;

  timer = setInterval(() => {
    $("temps").textContent = format((endTime - Date.now()) / 1000);
  }, 150);

  raf = requestAnimationFrame(animateProgress);

  while(!stopAsked && Date.now() < endTime){
    await phase("Inspirez", breath.i, 1.34);
    await phase("Gardez", breath.ph, 1.34);
    await phase("Expirez", breath.e, .68);
    await phase("Pause", breath.pb, .68);
  }

  clearInterval(timer);
  cancelAnimationFrame(raf);

  const completed = !stopAsked;

  running = false;
  stopAsked = false;

  $("stop").hidden = true;
  $("slider").disabled = false;
  $("protocolSelect").disabled = false;

  $("phase").textContent = completed ? "Terminé" : "Arrêté";
  $("phaseHint").textContent = completed ? "Séance terminée." : "Séance interrompue.";
  $("orb").style.transitionDuration = ".8s";
  $("orb").style.transform = "scale(.80)";
  $("temps").textContent = "00:00";
  setProgress(completed ? 1 : 0);

  if(completed) recordSession(true);

  playSoftClick();

  setTimeout(() => {
    if(!running){
      $("phase").textContent = "Êtes-vous prêt ?";
      $("phaseHint").textContent = "Touchez le cercle pour commencer.";
      $("temps").textContent = format(duree * 60);
      setProgress(0);
    }
  }, 1500);
}

function stopSession(){
  playSoftClick();
  stopAsked = true;
  $("phase").textContent = "Arrêt";
  $("phaseHint").textContent = "Arrêt demandé.";
}

function getHistory(){
  return JSON.parse(localStorage.getItem("respireMurHistory") || "[]");
}

function saveHistory(history){
  localStorage.setItem("respireMurHistory", JSON.stringify(history));
}

function recordSession(completed = true){
  const now = new Date();

  const entry = {
    id: Date.now(),
    date: now.toISOString().slice(0,10),
    time: now.toLocaleTimeString("fr-FR", {hour:"2-digit", minute:"2-digit"}),
    timestamp: now.getTime(),
    protocol: breath.name,
    zone: breath.zone,
    color: breath.color,
    inhale: breath.i,
    exhale: breath.e,
    holdTop: breath.ph,
    holdBottom: breath.pb,
    duration: duree,
    completed
  };

  const history = getHistory();
  history.unshift(entry);
  saveHistory(history.slice(0, 500));
  renderHistory();
}

function startOfToday(){
  const d = new Date();
  d.setHours(0,0,0,0);
  return d.getTime();
}

function startOfWeek(){
  const d = new Date();
  const day = d.getDay() || 7;
  d.setDate(d.getDate() - day + 1);
  d.setHours(0,0,0,0);
  return d.getTime();
}

function startOfMonth(){
  const d = new Date();
  d.setDate(1);
  d.setHours(0,0,0,0);
  return d.getTime();
}

function getFilteredHistory(){
  const history = getHistory();
  let start = startOfToday();
  if(historyView === "week") start = startOfWeek();
  if(historyView === "month") start = startOfMonth();
  return history.filter(item => item.timestamp >= start);
}

function getDominantZone(items){
  const zones = {};
  items.forEach(item => zones[item.zone] = (zones[item.zone] || 0) + 1);
  const sorted = Object.entries(zones).sort((a,b) => b[1] - a[1]);
  return sorted.length ? sorted[0][0] : "—";
}

function getMostUsedProtocol(items){
  const protocols = {};
  items.forEach(item => protocols[item.protocol] = (protocols[item.protocol] || 0) + 1);
  const sorted = Object.entries(protocols).sort((a,b) => b[1] - a[1]);
  return sorted.length ? sorted[0][0] : "—";
}

function renderHistory(){
  const list = $("historyList");
  const summary = $("historySummary");
  const items = getFilteredHistory();

  updateHistoryTabs();
  renderChart(items);

  if(items.length === 0){
    summary.textContent = "Aucune séance enregistrée pour cette période.";
    list.innerHTML = "";
    return;
  }

  const totalMinutes = items.reduce((sum, item) => sum + item.duration, 0);
  const dominantZone = getDominantZone(items);
  const mostUsed = getMostUsedProtocol(items);

  summary.innerHTML = `
    <strong>${items.length}</strong> séance(s) —
    <strong>${totalMinutes}</strong> min au total<br>
    Zone dominante : <strong>${dominantZone}</strong><br>
    Respiration la plus utilisée : <strong>${mostUsed}</strong>
  `;

  list.innerHTML = items.map(item => `
    <div class="history-item">
      <span class="history-dot" style="background:${item.color}"></span>
      <div>
        <strong>${item.protocol}</strong><br>
        <small>${formatReadableDate(item.timestamp)} à ${item.time} — ${item.zone}</small>
      </div>
      <small>${item.duration} min</small>
    </div>
  `).join("");
}

function formatReadableDate(timestamp){
  const d = new Date(timestamp);
  return d.toLocaleDateString("fr-FR", {day:"2-digit", month:"2-digit"});
}

function updateHistoryTabs(){
  $("historyDay").classList.toggle("active", historyView === "day");
  $("historyWeek").classList.toggle("active", historyView === "week");
  $("historyMonth").classList.toggle("active", historyView === "month");
}

function renderChart(items){
  const chart = $("historyChart");

  if(items.length === 0){
    chart.innerHTML = `<div class="chart-empty">Le graphique apparaîtra après votre première séance.</div>`;
    return;
  }

  const buckets = buildChartBuckets(items);
  const maxMinutes = Math.max(...buckets.map(b => b.minutes), 1);

  chart.innerHTML = `
    <div class="chart-bars">
      ${buckets.map(bucket => {
        const height = Math.max(5, Math.round((bucket.minutes / maxMinutes) * 100));
        const color = bucket.color || "rgba(255,255,255,.18)";
        return `
          <div class="chart-col">
            <div class="chart-value">${bucket.minutes ? bucket.minutes + "m" : ""}</div>
            <div class="chart-bar" style="height:${height}%; background:${color};"></div>
            <div class="chart-label">${bucket.label}</div>
          </div>
        `;
      }).join("")}
    </div>
  `;
}

function buildChartBuckets(items){
  if(historyView === "day") return buildDayBuckets(items);
  if(historyView === "week") return buildWeekBuckets(items);
  return buildMonthBuckets(items);
}

function buildDayBuckets(items){
  const buckets = [
    {label:"Matin", start:5, end:12, minutes:0, zones:[]},
    {label:"Midi", start:12, end:14, minutes:0, zones:[]},
    {label:"Après-midi", start:14, end:18, minutes:0, zones:[]},
    {label:"Soir", start:18, end:24, minutes:0, zones:[]}
  ];

  items.forEach(item => {
    const hour = new Date(item.timestamp).getHours();
    const bucket = buckets.find(b => hour >= b.start && hour < b.end) || buckets[0];
    bucket.minutes += item.duration;
    bucket.zones.push(item);
  });

  return buckets.map(addDominantColor);
}

function buildWeekBuckets(items){
  const labels = ["Lun","Mar","Mer","Jeu","Ven","Sam","Dim"];
  const buckets = labels.map(label => ({label, minutes:0, zones:[]}));

  items.forEach(item => {
    const d = new Date(item.timestamp);
    const day = d.getDay() || 7;
    buckets[day - 1].minutes += item.duration;
    buckets[day - 1].zones.push(item);
  });

  return buckets.map(addDominantColor);
}

function buildMonthBuckets(items){
  const buckets = [
    {label:"S1", minutes:0, zones:[]},
    {label:"S2", minutes:0, zones:[]},
    {label:"S3", minutes:0, zones:[]},
    {label:"S4", minutes:0, zones:[]},
    {label:"S5", minutes:0, zones:[]}
  ];

  items.forEach(item => {
    const d = new Date(item.timestamp);
    const weekIndex = Math.min(4, Math.floor((d.getDate() - 1) / 7));
    buckets[weekIndex].minutes += item.duration;
    buckets[weekIndex].zones.push(item);
  });

  return buckets.map(addDominantColor);
}

function addDominantColor(bucket){
  if(bucket.zones.length === 0){
    bucket.color = "rgba(255,255,255,.18)";
    return bucket;
  }

  const colors = {};
  bucket.zones.forEach(item => colors[item.color] = (colors[item.color] || 0) + 1);
  bucket.color = Object.entries(colors).sort((a,b) => b[1] - a[1])[0][0];
  return bucket;
}

function exportHistory(){
  const history = getHistory();
  const data = JSON.stringify(history, null, 2);
  const blob = new Blob([data], {type:"application/json"});
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  const date = new Date().toISOString().slice(0,10);

  a.href = url;
  a.download = "historique-neuroflex-" + date + ".json";
  a.click();

  URL.revokeObjectURL(url);
}

function importHistoryFile(event){
  const file = event.target.files[0];
  if(!file) return;

  const reader = new FileReader();

  reader.onload = e => {
    try{
      const imported = JSON.parse(e.target.result);

      if(!Array.isArray(imported)){
        alert("Le fichier ne semble pas être un historique valide.");
        return;
      }

      const current = getHistory();
      const merged = [...imported, ...current];
      const unique = [];
      const seen = new Set();

      merged.forEach(item => {
        const key = item.id || item.timestamp + "-" + item.protocol;
        if(!seen.has(key)){
          seen.add(key);
          unique.push(item);
        }
      });

      unique.sort((a,b) => b.timestamp - a.timestamp);
      saveHistory(unique.slice(0,500));
      renderHistory();
      alert("Historique importé.");
    }catch(error){
      alert("Impossible de lire ce fichier.");
    }
  };

  reader.readAsText(file);
}

document.querySelectorAll(".tabbar button").forEach(button => {
  button.addEventListener("click", () => {
    setActiveTab(button.dataset.tab);
  });
});

$("protocolSelect").addEventListener("change", e => {
  playSoftClick();
  setProtocol(e.target.value);
});

$("zoneButton").addEventListener("click", changeZoneByButton);

$("soundToggle").addEventListener("click", () => {
  if(!soundEnabled){
    unlockAudio();
  } else {
    playSoftClick();
    soundEnabled = false;
    $("soundToggle").textContent = "Activer le son";
  }
});

$("slider").addEventListener("input", e => {
  playSoftClick();
  setBreathFromSlider(e.target.value);
});

$("btnBleu").addEventListener("click", () => {
  playSoftClick();
  setSlider(-2);
});

$("btnVert").addEventListener("click", () => {
  playSoftClick();
  setSlider(0);
});

$("btnRouge").addEventListener("click", () => {
  playSoftClick();
  setSlider(3);
});

$("moins").addEventListener("click", () => {
  if(running) return;
  playSoftClick();
  duree = Math.max(1, duree - 1);
  breath.duration = duree;
  render();
});

$("plus").addEventListener("click", () => {
  if(running) return;
  playSoftClick();
  duree = Math.min(10, duree + 1);
  breath.duration = duree;
  render();
});

$("applyManual").addEventListener("click", applyManual);

$("orb").addEventListener("click", () => {
  if(!soundEnabled) initAudio();
  runSession();
});

$("stop").addEventListener("click", stopSession);

$("historyDay").addEventListener("click", () => {
  historyView = "day";
  renderHistory();
});

$("historyWeek").addEventListener("click", () => {
  historyView = "week";
  renderHistory();
});

$("historyMonth").addEventListener("click", () => {
  historyView = "month";
  renderHistory();
});

$("clearHistory").addEventListener("click", () => {
  const ok = confirm("Effacer tout l’historique neuroFlex ?");
  if(!ok) return;
  saveHistory([]);
  renderHistory();
});

$("exportHistory").addEventListener("click", exportHistory);
$("importHistory").addEventListener("change", importHistoryFile);

setProtocol("365");
renderHistory();
</script>
</body>
</html>
